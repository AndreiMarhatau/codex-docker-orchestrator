{
  "name": "codex-docker-orchestrator-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock:dev": "VITE_ENABLE_MOCK_DATA=1 vite --host 0.0.0.0",
    "build": "vite build",
    "mock:build": "VITE_ENABLE_MOCK_DATA=1 VITE_BUILD_OUT_DIR=dist-mock vite build",
    "preview": "vite preview",
    "mock:preview": "sh -c 'VITE_ENABLE_MOCK_DATA=1 vite preview --host 0.0.0.0 --strictPort --port \"${MOCK_UI_PORT:-4173}\" --outDir \"${MOCK_UI_OUT_DIR:-dist-mock}\"'",
    "test": "NODE_OPTIONS='--require ./tests/fs-mkdir-patch.cjs' vitest run --coverage",
    "lint": "eslint --rulesdir eslint-rules --ext .js,.jsx src tests --max-warnings=0"
  },
  "dependencies": {
    "@emotion/react": "11.13.3",
    "@emotion/styled": "11.13.0",
    "@mui/icons-material": "5.16.7",
    "@mui/material": "5.16.7",
    "@popperjs/core": "^2.11.8",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.5.0",
    "@testing-library/react": "14.3.1",
    "@testing-library/user-event": "14.5.2",
    "@vitest/coverage-v8": "2.1.1",
    "@vitejs/plugin-react": "4.3.2",
    "eslint": "8.57.1",
    "eslint-plugin-react": "7.37.1",
    "eslint-plugin-vitest": "0.5.4",
    "jsdom": "24.1.3",
    "rollup": "npm:@rollup/wasm-node@^4.53.5",
    "vite": "5.4.2",
    "vitest": "2.1.1"
  }
}
